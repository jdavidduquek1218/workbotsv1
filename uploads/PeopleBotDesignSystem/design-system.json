{
  "name": "PeopleBot Design System",
  "version": "1.0.0",
  "description": "Sistema de diseño completo de PeopleBot landing page",
  "colors": {
    "primary": {
      "main": "#4F46E5",
      "hover": "#4338CA",
      "light": "rgba(79, 70, 229, 0.15)",
      "border": "rgba(79, 70, 229, 0.25)",
      "glow": "rgba(79, 70, 229, 0.4)",
      "shadow": "rgba(79, 70, 229, 0.25)",
      "gradient": "rgba(79, 70, 229, 0.22)"
    },
    "accent": {
      "green": "#25D366",
      "greenDark": "#1b9e4d"
    },
    "neutral": {
      "darkBg": "#09090B",
      "lightBg": "#FAFAF8",
      "white": "#fff",
      "grayBorder": "#E4E4E7",
      "grayTextPrimary": "#52525B",
      "grayTextSecondary": "#71717A",
      "grayLight": "#E8E8E8"
    },
    "transparencies": {
      "white03": "rgba(255, 255, 255, 0.03)",
      "white06": "rgba(255, 255, 255, 0.06)",
      "white07": "rgba(255, 255, 255, 0.07)",
      "white10": "rgba(255, 255, 255, 0.1)",
      "white18": "rgba(255, 255, 255, 0.18)",
      "white25": "rgba(255, 255, 255, 0.25)",
      "white35": "rgba(255, 255, 255, 0.35)",
      "white40": "rgba(255, 255, 255, 0.4)",
      "white42": "rgba(255, 255, 255, 0.42)",
      "white45": "rgba(255, 255, 255, 0.45)",
      "white55": "rgba(255, 255, 255, 0.55)",
      "white65": "rgba(255, 255, 255, 0.65)",
      "white80": "rgba(255, 255, 255, 0.8)"
    },
    "shadow": {
      "dark": "rgba(0, 0, 0, 0.13)"
    }
  },
  "typography": {
    "fontFamilies": {
      "heading": "'Space Grotesk', sans-serif",
      "body": "'Plus Jakarta Sans', sans-serif"
    },
    "fontSizes": {
      "h1": "clamp(52px, 7.5vw, 92px)",
      "h2": "clamp(30px, 4vw, 52px)",
      "h2Section": "clamp(26px, 2.8vw, 38px)",
      "h3": "21px",
      "pLarge": "clamp(17px, 2vw, 21px)",
      "pNormal": "16px",
      "pSmall": "14px",
      "pXs": "13px",
      "label": "12px",
      "labelUppercase": "11px"
    },
    "fontWeights": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "extrabold": 800
    },
    "lineHeights": {
      "tight": 1.0,
      "normal": 1.3,
      "relaxed": 1.55,
      "loose": 1.72
    },
    "letterSpacing": {
      "tight": "-0.03em",
      "normal": "-0.02em",
      "wide": "0.02em",
      "wider": "0.18em",
      "widest": "0.2em"
    }
  },
  "spacing": {
    "xs": "8px",
    "sm": "12px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px",
    "2xl": "44px",
    "3xl": "56px",
    "4xl": "60px",
    "5xl": "88px",
    "6xl": "100px",
    "7xl": "148px"
  },
  "borderRadius": {
    "sm": "8px",
    "md": "10px",
    "lg": "14px",
    "xl": "18px",
    "pill": "100px"
  },
  "shadows": {
    "hover": "0 12px 40px rgba(0, 0, 0, 0.13)",
    "button": "0 0 0 1px rgba(79, 70, 229, 0.4), 0 4px 24px rgba(79, 70, 229, 0.25)"
  },
  "transitions": {
    "fast": "0.2s",
    "normal": "0.25s",
    "slow": "0.5s"
  },
  "animations": {
    "blink": {
      "keyframes": {
        "0%": "opacity: 1",
        "50%": "opacity: 0.3",
        "100%": "opacity: 1"
      },
      "duration": "2s",
      "iterationCount": "infinite"
    },
    "fadeUp": {
      "keyframes": {
        "from": "opacity: 0; transform: translateY(20px)",
        "to": "opacity: 1; transform: translateY(0)"
      },
      "duration": "0.7s",
      "fillMode": "both"
    },
    "floatCard": {
      "keyframes": {
        "0%": "transform: translateY(0px)",
        "50%": "transform: translateY(-7px)",
        "100%": "transform: translateY(0px)"
      },
      "duration": "0.6s",
      "timingFunction": "ease-in-out",
      "iterationCount": "infinite"
    }
  },
  "components": {
    "button": {
      "primary": {
        "background": "#4F46E5",
        "color": "#fff",
        "fontSize": "16px",
        "fontWeight": 600,
        "padding": "16px 32px",
        "borderRadius": "10px",
        "boxShadow": "0 0 0 1px rgba(79,70,229,.4), 0 4px 24px rgba(79,70,229,.25)",
        "hover": {
          "background": "#4338CA",
          "transform": "translateY(-1px)"
        }
      },
      "secondary": {
        "fontSize": "15px",
        "fontWeight": 500,
        "color": "rgba(255, 255, 255, 0.4)",
        "background": "transparent",
        "hover": {
          "color": "rgba(255, 255, 255, 0.8)"
        }
      }
    },
    "card": {
      "dark": {
        "background": "#09090B",
        "borderRadius": "18px",
        "padding": "44px 40px 48px",
        "minHeight": "500px",
        "position": "relative",
        "overflow": "hidden"
      },
      "light": {
        "background": "#fff",
        "border": "1px solid #E8E8E8",
        "borderRadius": "18px",
        "padding": "44px 40px 20px",
        "minHeight": "500px"
      }
    },
    "badge": {
      "display": "inline-flex",
      "alignItems": "center",
      "gap": "8px",
      "border": "1px solid rgba(255, 255, 255, 0.1)",
      "borderRadius": "100px",
      "padding": "6px 18px",
      "background": "rgba(255, 255, 255, 0.03)",
      "fontSize": "13px",
      "fontWeight": 500,
      "color": "rgba(255, 255, 255, 0.55)"
    },
    "nav": {
      "height": "64px",
      "padding": "0 32px",
      "background": "transparent",
      "backdropFilter": "none",
      "scrolled": {
        "background": "rgba(250, 250, 248, 0.96)",
        "backdropFilter": "blur(16px)",
        "borderBottom": "1px solid #E4E4E7"
      }
    }
  },
  "grids": {
    "2col": {
      "columns": "1fr 1fr",
      "gap": "32px"
    },
    "3col": {
      "columns": "1fr 1fr 1fr",
      "gap": "14px"
    },
    "4col": {
      "columns": "1fr 1fr 1fr 1fr",
      "gap": "16px"
    }
  },
  "containers": {
    "max": "1120px",
    "hero": "840px",
    "sm": "680px"
  },
  "responsive": {
    "breakpoint": "768px",
    "rules": {
      "navLinks": "display: none",
      "navToggle": "display: flex",
      "2col": "grid-template-columns: 1fr",
      "3col": "grid-template-columns: 1fr",
      "4col": "grid-template-columns: 1fr 1fr"
    }
  }
}
